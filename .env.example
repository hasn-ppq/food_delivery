APP_NAME="Food Delivery"
APP_ENV=production
APP_KEY=base64:PUT_YOUR_KEY_HERE
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# =========================
# DATABASE (FROM RAILWAY)
# =========================
DB_CONNECTION=mysql
DB_HOST=FROM_RAILWAY
DB_PORT=3306
DB_DATABASE=FROM_RAILWAY
DB_USERNAME=FROM_RAILWAY
DB_PASSWORD=FROM_RAILWAY

# =========================
# SESSION / CACHE / QUEUE
# =========================
SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

# =========================
# BROADCASTING (REVERB)
# =========================
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=710919
REVERB_APP_KEY=YOUR_KEY
REVERB_APP_SECRET=YOUR_SECRET

REVERB_HOST=your-app.up.railway.app
REVERB_PORT=443
REVERB_SCHEME=https

# VITE (Frontend)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

VITE_APP_NAME="${APP_NAME}"

# =========================
# REDIS (FROM RAILWAY)
# =========================
REDIS_CLIENT=phpredis
REDIS_HOST=FROM_RAILWAY
REDIS_PASSWORD=null
REDIS_PORT=6379

# =========================
# MAIL (Gmail أو SMTP)
# =========================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =========================
# FIREBASE
# =========================
FIREBASE_CREDENTIALS=storage/app/firebase.json